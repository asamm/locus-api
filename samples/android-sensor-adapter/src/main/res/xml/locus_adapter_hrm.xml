<?xml version="1.0" encoding="utf-8"?><!--
    Manifest for HrmAdapterService — a BT4 / GATT example: a standard BLE Heart Rate strap
    (Polar / Wahoo / Garmin / Suunto) → SENSOR_HEART_RATE.

    This app ships a second, independent adapter service (NmeaSpeedAdapterService, see
    res/xml/locus_adapter_nmea.xml) for a BT3 example — one service per device type keeps each
    example focused, and Locus discovers each service separately.

    Locus reads this XML without binding the service — every static attribute here is part of
    the picker's bind-free discovery surface.

    Schema reference:
        docs/android/guides/adapter-apps/manifest-schema.md (in the locus-api repo)
-->
<adapter
    apiVersion="1"
    id="com.asamm.locus.api.sample.sensoradapter/HrmAdapter"
    displayName="@string/service_hrm_name">

    <deviceType
        id="ble-hrm"
        connectionType="BT4"
        displayName="@string/adapter_hrm_device_type"
        icon="@drawable/ic_hrm">

        <refId variable="SENSOR_HEART_RATE" />

        <!--
            Heart Rate Measurement characteristic (0x2A37) on the standard
            Heart Rate Service (0x180D). Compliant straps advertise the
            service UUID, so Locus's BT4 scan will surface them without
            needing a name filter.
        -->
        <characteristic
            uuid="00002a37-0000-1000-8000-00805f9b34fb"
            mode="NOTIFY" />
    </deviceType>
</adapter>
