<?xml version="1.0" encoding="utf-8"?><!--
    Manifest for NmeaSpeedAdapterService — NMEA GNSS receiver → SENSOR_SPEED, parsed from the
    speed-over-ground field of RMC sentences. The same service handles two stream transports:

      - bt3-nmea-speed: Bluetooth Classic / SPP. Pair the receiver in Android Bluetooth settings,
        then pick it from the bonded list in Locus.
      - usb-nmea-speed: USB-serial. Plug in the receiver; Locus grants the USB permission and picks
        it from the attached-device list.

    The parser is identical for both — only connectionType (and, for USB, the device's vendorId /
    productId) differs. No <characteristic>: a serial stream is undifferentiated bytes, so Locus
    hands raw bytes to parseData with an empty `source` and the adapter reassembles NMEA lines.

    A separate adapter service from the BT4 HRM one (res/xml/locus_adapter_hrm.xml) — so each
    example stays focused and multi-service discovery is exercised.

    Schema reference:
        docs/android/guides/adapter-apps/manifest-schema.md (in the locus-api repo)
-->
<adapter
    apiVersion="1"
    id="com.asamm.locus.api.sample.sensoradapter/NmeaSpeedAdapter"
    displayName="@string/service_nmea_speed_name">

    <deviceType
        id="bt3-nmea-speed"
        connectionType="BT3"
        displayName="@string/adapter_nmea_speed_bt3_device_type">

        <refId variable="SENSOR_SPEED" />
    </deviceType>

    <!--
        USB-serial. vendorId / productId must match YOUR receiver so Locus's serial prober
        recognises it — change them to your device's ids. The values below are a Prolific PL2303
        USB-serial bridge (vendorId 1659 = 0x067B, productId 8963 = 0x2303), a common GNSS-receiver
        chip. Serial parameters (baudRate / dataBits / stopBits / parity) are omitted, so they
        default to the GNSS-typical 4800 / 8 / 1 / none — which is what this receiver uses.
    -->
    <deviceType
        id="usb-nmea-speed"
        connectionType="USB"
        displayName="@string/adapter_nmea_speed_usb_device_type"
        vendorId="1659"
        productId="8963">

        <refId variable="SENSOR_SPEED" />
    </deviceType>
</adapter>
