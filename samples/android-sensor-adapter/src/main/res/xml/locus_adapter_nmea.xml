<?xml version="1.0" encoding="utf-8"?><!--
    Manifest for NmeaSpeedAdapterService — a BT3 (Bluetooth Classic / SPP) example: an NMEA GNSS
    receiver → SENSOR_SPEED, parsed from the speed-over-ground field of RMC sentences.

    A separate adapter service from the BT4 HRM one (res/xml/locus_adapter_hrm.xml) — one service per
    device type, so each example stays focused and multi-service discovery is exercised.

    No <characteristic>: Bluetooth Classic is an undifferentiated byte stream, so Locus hands each
    line to parseData with an empty `source`. The user pairs the receiver in Android Bluetooth
    settings, then picks it from the bonded list.

    Schema reference:
        docs/android/guides/adapter-apps/manifest-schema.md (in the locus-api repo)
-->
<adapter
    apiVersion="1"
    id="com.asamm.locus.api.sample.sensoradapter/NmeaSpeedAdapter"
    displayName="@string/service_nmea_speed_name">

    <deviceType
        id="bt3-nmea-speed"
        connectionType="BT3"
        displayName="@string/adapter_nmea_speed_device_type">

        <refId variable="SENSOR_SPEED" />
    </deviceType>
</adapter>
