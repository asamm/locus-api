<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <!-- Info screen — explains what the app exposes and how to pair it in Locus. -->
        <activity
            android:name=".InfoActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Two independent adapter services, one per device type. Each declares the
            ACTION_SENSOR_ADAPTER_PARSER intent-filter + SENSOR_ADAPTER permission and points its
            <meta-data> at its own device-type catalogue XML; Locus discovers each separately.
        -->

        <!-- BT3 / SPP: NMEA GNSS receiver → speed. -->
        <service
            android:name=".NmeaSpeedAdapterService"
            android:exported="true"
            android:label="@string/service_nmea_speed_name"
            android:permission="com.asamm.locus.permission.SENSOR_ADAPTER">

            <intent-filter>
                <action android:name="locus.api.android.ACTION_SENSOR_ADAPTER_PARSER" />
            </intent-filter>

            <meta-data
                android:name="locus.api.android.SENSOR_ADAPTER"
                android:resource="@xml/locus_adapter_nmea" />
        </service>

        <!-- BT4 / GATT: standard BLE Heart Rate strap. -->
        <service
            android:name=".HrmAdapterService"
            android:exported="true"
            android:icon="@drawable/ic_hrm"
            android:label="@string/service_hrm_name"
            android:permission="com.asamm.locus.permission.SENSOR_ADAPTER">

            <intent-filter>
                <action android:name="locus.api.android.ACTION_SENSOR_ADAPTER_PARSER" />
            </intent-filter>

            <meta-data
                android:name="locus.api.android.SENSOR_ADAPTER"
                android:resource="@xml/locus_adapter_hrm" />
        </service>

    </application>

</manifest>
